# -----------------------------------------------------------------------------
# 논문 분석 SaaS - 환경 변수 설정 가이드 (.env.example)
# 이 파일을 .env.local로 복사하여 실제 값을 입력하세요.
# -----------------------------------------------------------------------------

# [1] AI API Keys
# Anthropic Claude API (심층 분석용) - https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini API (기본 분석용) - https://aistudio.google.com
GOOGLE_GENERATIVE_AI_API_KEY=your_google_gemini_api_key_here

# [1-1] Academic Data Pipeline API Keys
# OpenAlex는 일반적으로 키가 필요 없지만, 향후 프록시/기관 키를 사용할 경우에만 설정합니다.
OPENALEX_API_KEY=

# Semantic Scholar는 키가 없으면 자동으로 건너뜁니다.
SEMANTIC_SCHOLAR_API_KEY=

# CORE는 API 키가 필요합니다. 키가 없으면 CORE 검색은 빈 배열로 fallback됩니다.
CORE_API_KEY=

# [1-2] Weekly Archive Update
# Vercel Cron 또는 GitHub Actions가 /api/archive/weekly-update를 호출할 때 사용하는 서버 전용 secret입니다.
ARCHIVE_CRON_SECRET=change_this_to_a_long_random_secret

# [2] Supabase Settings
# Supabase 프로젝트 설정 -> API 메뉴에서 확인 가능
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_public_anon_key

# 서버사이드 보안 작업용 (관리자 기능 필수)
# [CAUTION] 절대 클라이언트 측이나 소스 코드에 노출하지 마세요.
SUPABASE_SERVICE_ROLE_KEY=your_secret_service_role_key

# [3] App Settings
# 배포된 사이트 주소 (결제 리다이렉션 등에 사용)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# [4] Deployment Flags
# 개발 모드 활성화 (true/false)
NEXT_PUBLIC_DEBUG_MODE=false
